# Secrets — injected by deploy-service from Infisical at deploy time.
# Never commit real values. See services.yml in the HomeLab repo for the
# Infisical paths these are fetched from.
TUNNEL_TOKEN=

PIHOLE_WEB_PASSWORD=

# Non-secret
TZ=Australia/Sydney

# Non-secret network config — injected by deploy-service from Infisical
IP_OBSERVE=
IP_SVC_01=
IP_SVC_02=
IP_SVC_03=
